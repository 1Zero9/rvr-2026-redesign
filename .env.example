# ─────────────────────────────────────────────────────────────────────────────
# Rivervalley Rangers AFC — Environment Variable Schema
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
#
# To pull current values from Vercel (requires project access):
#   vercel env pull .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Vercel OIDC (auto-generated by `vercel env pull`) ────────────────────────
VERCEL_OIDC_TOKEN=""

# ── Database (Prisma Postgres via Vercel Marketplace) ────────────────────────
# All three should point to the same connection string.
# Obtain from: Vercel Dashboard → Storage → your Prisma Postgres instance
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
POSTGRES_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
PRISMA_DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── Cron job security ─────────────────────────────────────────────────────────
# Bearer token required by /api/cron/* endpoints.
# Must match the value configured in Vercel Cron settings.
# Generate: openssl rand -base64 32
CRON_SECRET=""

# ── Auth.js session secret ────────────────────────────────────────────────────
# Signs and verifies session tokens.
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# ── Resend (transactional email) ──────────────────────────────────────────────
# API key from https://resend.com/api-keys
AUTH_RESEND_KEY=""

# Verified sender address in Resend (must match your domain)
EMAIL_FROM="noreply@yourdomain.ie"

# ── Cloudflare Turnstile (bot protection) ────────────────────────────────────
# Create a widget at https://dash.cloudflare.com → Turnstile
# Site key is safe to expose publicly (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── Stripe payments ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── DDSL / SportLoMo data ─────────────────────────────────────────────────────
SPORTLOMO_API_KEY=""
SPORTLOMO_BASE_URL=""
SPORTLOMO_CLUB_ID=""
SPORTLOMO_SEASON="2025/26"

# ── Safeguarding email alerts ─────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
COMPLIANCE_EMAIL_FROM="noreply@rivervalleyrangers.ie"
WELFARE_OFFICER_EMAIL=""
