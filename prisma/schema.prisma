generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Vetting status for any adult who needs safeguarding clearance.
enum VettingStatus {
  PENDING
  APPROVED
  EXPIRED
}

/// Consent status for privacy-sensitive youth profile features.
enum ConsentStatus {
  NOT_REQUESTED
  PENDING
  SIGNED
  REVOKED
}

/// Payment state for campaign orders, donations, and fundraising entries.
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/// Publication state for public-facing community submissions.
enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Campaign type for community fundraising modules.
enum FundraisingCampaignType {
  KIT_DESIGN
  FUN_RUN
  LOTTO
  DONATION
}

/// Kit and event merchandise sizing options.
enum ClothingSize {
  CHILD_SMALL
  CHILD_MEDIUM
  CHILD_LARGE
  ADULT_SMALL
  ADULT_MEDIUM
  ADULT_LARGE
  ADULT_EXTRA_LARGE
}

/// Privacy-guarded player profile for mobile player cards.
model PlayerProfile {
  id                    String          @id @default(cuid())
  firstName             String
  lastName              String
  displayName           String
  yearOfBirth           Int
  teamName              String?
  position              String?
  profileSummary        String?
  cardImageUrl          String?
  isPrivate             Boolean         @default(true)
  photoConsentStatus    ConsentStatus   @default(NOT_REQUESTED)
  medicalConsentStatus  ConsentStatus   @default(NOT_REQUESTED)
  dataConsentStatus     ConsentStatus   @default(NOT_REQUESTED)
  parentConsents        ParentConsent[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([teamName])
  @@index([isPrivate])
  @@index([lastName, firstName])
  @@index([photoConsentStatus, dataConsentStatus])
}

/// Digitally signed consent record for a player profile.
model ParentConsent {
  id                 String        @id @default(cuid())
  playerProfileId    String
  playerProfile      PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  parentName         String
  parentEmail        String
  signatureHash      String
  photoRelease       Boolean       @default(false)
  medicalTreatment   Boolean       @default(false)
  dataProcessing     Boolean       @default(false)
  signedAt           DateTime      @default(now())
  revokedAt          DateTime?

  @@index([parentEmail])
  @@index([playerProfileId, signedAt])
}

/// Coach record for compliance checks, team assignment, and training history.
model CoachProfile {
  id                         String        @id @default(cuid())
  firstName                  String
  lastName                   String
  email                      String        @unique
  phone                      String?
  teamName                   String?
  qualificationLevel         String?
  vettingStatus              VettingStatus @default(PENDING)
  vettingSubmittedAt         DateTime?
  vettingApprovedAt          DateTime?
  vettingExpiresAt           DateTime?
  safeguardingTrainingAt     DateTime?
  isActive                   Boolean       @default(true)
  complianceChecks           ComplianceCheck[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  @@index([teamName])
  @@index([vettingStatus])
  @@index([isActive])
  @@index([lastName, firstName])
}

/// Club welfare contact and policy ownership record.
model ClubWelfareContact {
  id                         String        @id @default(cuid())
  roleTitle                  String
  firstName                  String
  lastName                   String
  email                      String
  phone                      String?
  vettingStatus              VettingStatus @default(PENDING)
  safeguardingTrainingAt     DateTime?
  policyOwner                Boolean       @default(false)
  publicContact              Boolean       @default(false)
  isActive                   Boolean       @default(true)
  complianceChecks           ComplianceCheck[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  @@index([roleTitle])
  @@index([vettingStatus])
  @@index([publicContact, isActive])
}

/// Compliance check that can be attached to either a coach or welfare contact.
model ComplianceCheck {
  id                    String              @id @default(cuid())
  coachProfileId        String?
  coachProfile          CoachProfile?       @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  welfareContactId      String?
  welfareContact        ClubWelfareContact? @relation(fields: [welfareContactId], references: [id], onDelete: Cascade)
  checkName             String
  status                VettingStatus       @default(PENDING)
  dueAt                 DateTime?
  completedAt           DateTime?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([coachProfileId, status])
  @@index([welfareContactId, status])
  @@index([status, dueAt])
}

/// Community fundraising campaign for kit design, events, donations, and lotto.
model FundraisingCampaign {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  title               String
  campaignType        FundraisingCampaignType
  targetAmountCents   Int
  raisedAmountCents   Int                     @default(0)
  startsAt            DateTime?
  endsAt              DateTime?
  isActive            Boolean                 @default(true)
  donations           Donation[]
  kitSubmissions      KitDesignSubmission[]
  funRunRegistrations FunRunRegistration[]
  lottoDraws          LottoDraw[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([campaignType, isActive])
  @@index([slug])
}

/// Donation or sponsorship payment attached to a fundraising campaign.
model Donation {
  id                    String              @id @default(cuid())
  campaignId            String
  campaign              FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorName             String?
  donorEmail            String?
  amountCents           Int
  message               String?
  paymentStatus         PaymentStatus       @default(PENDING)
  paymentReference      String?             @unique
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([campaignId, paymentStatus])
  @@index([donorEmail])
}

/// Public kit design submission with moderation and vote tracking.
model KitDesignSubmission {
  id                String              @id @default(cuid())
  campaignId        String
  campaign          FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submitterName     String
  submitterEmail    String
  teamName          String?
  designFileUrl     String
  thumbnailUrl      String?
  moderationStatus  ModerationStatus    @default(PENDING)
  voteCount         Int                 @default(0)
  votes             KitDesignVote[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([campaignId, moderationStatus])
  @@index([voteCount])
}

/// Vote record used to prevent repeated voting on the same kit design.
model KitDesignVote {
  id                    String              @id @default(cuid())
  kitDesignSubmissionId String
  kitDesignSubmission   KitDesignSubmission @relation(fields: [kitDesignSubmissionId], references: [id], onDelete: Cascade)
  voterFingerprint      String
  createdAt             DateTime            @default(now())

  @@unique([kitDesignSubmissionId, voterFingerprint])
  @@index([voterFingerprint])
}

/// Fun run registration with optional merchandise and payment tracking.
model FunRunRegistration {
  id                   String              @id @default(cuid())
  campaignId           String
  campaign             FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participantName      String
  participantAge       Int
  guardianName         String
  guardianEmail        String
  guardianPhone        String
  clothingSize         ClothingSize?
  powderPackQuantity   Int                 @default(0)
  sunglassesQuantity   Int                 @default(0)
  totalAmountCents     Int
  paymentStatus        PaymentStatus       @default(PENDING)
  paymentReference     String?             @unique
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([campaignId, paymentStatus])
  @@index([guardianEmail])
}

/// Weekly lotto draw information for a public headless widget.
model LottoDraw {
  id                String              @id @default(cuid())
  campaignId        String
  campaign          FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  drawDate          DateTime
  jackpotCents      Int
  winningNumbers    Int[]
  bonusNumber       Int?
  winnerSummary     String?
  providerName      String
  providerUrl       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([campaignId, drawDate])
}
