generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Vetting status for any adult who needs safeguarding clearance.
enum VettingStatus {
  PENDING
  APPROVED
  EXPIRED
}

/// Consent status for privacy-sensitive youth profile features.
enum ConsentStatus {
  NOT_REQUESTED
  PENDING
  SIGNED
  REVOKED
}

/// Payment state for campaign orders, donations, and fundraising entries.
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/// Publication state for public-facing community submissions.
enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Campaign type for community fundraising modules.
enum FundraisingCampaignType {
  KIT_DESIGN
  FUN_RUN
  LOTTO
  DONATION
}

/// Kit and event merchandise sizing options.
enum ClothingSize {
  CHILD_SMALL
  CHILD_MEDIUM
  CHILD_LARGE
  ADULT_SMALL
  ADULT_MEDIUM
  ADULT_LARGE
  ADULT_EXTRA_LARGE
}

enum RegistrationStatus {
  NEW
  CONTACTED
  WAITLISTED
  ENROLLED
  DECLINED
}

enum PlayerGender {
  MALE
  FEMALE
}

/// Category for public-facing club announcements.
enum AnnouncementCategory {
  RECRUITMENT
  EVENT
  NEWS
  VOLUNTEER
}

/// Privacy-guarded player profile for mobile player cards.
model PlayerProfile {
  id                   String          @id @default(cuid())
  firstName            String
  lastName             String
  displayName          String
  yearOfBirth          Int
  teamName             String?
  position             String?
  profileSummary       String?
  cardImageUrl         String?
  isPrivate            Boolean            @default(true)
  registrationStatus   RegistrationStatus @default(NEW)
  gender               PlayerGender?
  notes                String?
  photoConsentStatus   ConsentStatus      @default(NOT_REQUESTED)
  medicalConsentStatus ConsentStatus      @default(NOT_REQUESTED)
  dataConsentStatus    ConsentStatus      @default(NOT_REQUESTED)
  parentConsents       ParentConsent[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([teamName])
  @@index([isPrivate])
  @@index([registrationStatus, createdAt])
  @@index([lastName, firstName])
  @@index([photoConsentStatus, dataConsentStatus])
}

/// Digitally signed consent record for a player profile.
model ParentConsent {
  id               String        @id @default(cuid())
  playerProfileId  String
  playerProfile    PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  parentName       String
  parentEmail      String
  parentPhone      String?
  signatureHash    String
  photoRelease     Boolean       @default(false)
  medicalTreatment Boolean       @default(false)
  dataProcessing   Boolean       @default(false)
  signedAt         DateTime      @default(now())
  revokedAt        DateTime?

  @@index([parentEmail])
  @@index([playerProfileId, signedAt])
}

/// Coach record for compliance checks, team assignment, and training history.
model CoachProfile {
  id                     String            @id @default(cuid())
  firstName              String
  lastName               String
  email                  String            @unique
  phone                  String?
  teamName               String?
  qualificationLevel     String?
  vettingStatus          VettingStatus     @default(PENDING)
  vettingSubmittedAt     DateTime?
  vettingApprovedAt      DateTime?
  vettingExpiresAt       DateTime?
  safeguardingTrainingAt DateTime?
  isActive               Boolean           @default(true)
  complianceChecks       ComplianceCheck[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([teamName])
  @@index([vettingStatus])
  @@index([isActive])
  @@index([lastName, firstName])
}

/// Club welfare contact and policy ownership record.
model ClubWelfareContact {
  id                     String            @id @default(cuid())
  roleTitle              String
  firstName              String
  lastName               String
  email                  String
  phone                  String?
  vettingStatus          VettingStatus     @default(PENDING)
  safeguardingTrainingAt DateTime?
  policyOwner            Boolean           @default(false)
  publicContact          Boolean           @default(false)
  isActive               Boolean           @default(true)
  complianceChecks       ComplianceCheck[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([roleTitle])
  @@index([vettingStatus])
  @@index([publicContact, isActive])
}

/// Compliance check that can be attached to either a coach or welfare contact.
model ComplianceCheck {
  id               String              @id @default(cuid())
  coachProfileId   String?
  coachProfile     CoachProfile?       @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  welfareContactId String?
  welfareContact   ClubWelfareContact? @relation(fields: [welfareContactId], references: [id], onDelete: Cascade)
  checkName        String
  status           VettingStatus       @default(PENDING)
  dueAt            DateTime?
  completedAt      DateTime?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([coachProfileId, status])
  @@index([welfareContactId, status])
  @@index([status, dueAt])
}

/// Community fundraising campaign for kit design, events, donations, and lotto.
model FundraisingCampaign {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  title               String
  campaignType        FundraisingCampaignType
  targetAmountCents   Int
  raisedAmountCents   Int                     @default(0)
  startsAt            DateTime?
  endsAt              DateTime?
  isActive            Boolean                 @default(true)
  donations           Donation[]
  kitSubmissions      KitDesignSubmission[]
  funRunRegistrations FunRunRegistration[]
  lottoDraws          LottoDraw[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([campaignType, isActive])
  @@index([slug])
}

/// Donation or sponsorship payment attached to a fundraising campaign.
model Donation {
  id               String              @id @default(cuid())
  campaignId       String
  campaign         FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorName        String?
  donorEmail       String?
  amountCents      Int
  message          String?
  paymentStatus    PaymentStatus       @default(PENDING)
  paymentReference String?             @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([campaignId, paymentStatus])
  @@index([donorEmail])
}

/// Public kit design submission with moderation and vote tracking.
model KitDesignSubmission {
  id               String              @id @default(cuid())
  campaignId       String
  campaign         FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submitterName    String
  submitterEmail   String
  teamName         String?
  designFileUrl    String
  thumbnailUrl     String?
  moderationStatus ModerationStatus    @default(PENDING)
  voteCount        Int                 @default(0)
  votes            KitDesignVote[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([campaignId, moderationStatus])
  @@index([voteCount])
}

/// Vote record used to prevent repeated voting on the same kit design.
model KitDesignVote {
  id                    String              @id @default(cuid())
  kitDesignSubmissionId String
  kitDesignSubmission   KitDesignSubmission @relation(fields: [kitDesignSubmissionId], references: [id], onDelete: Cascade)
  voterFingerprint      String
  createdAt             DateTime            @default(now())

  @@unique([kitDesignSubmissionId, voterFingerprint])
  @@index([voterFingerprint])
}

/// Fun run registration with optional merchandise and payment tracking.
model FunRunRegistration {
  id                 String              @id @default(cuid())
  campaignId         String
  campaign           FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participantName    String
  participantAge     Int
  guardianName       String
  guardianEmail      String
  guardianPhone      String
  clothingSize       ClothingSize?
  powderPackQuantity Int                 @default(0)
  sunglassesQuantity Int                 @default(0)
  totalAmountCents   Int
  paymentStatus      PaymentStatus       @default(PENDING)
  paymentReference   String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([campaignId, paymentStatus])
  @@index([guardianEmail])
}

/// Weekly lotto draw information for a public headless widget.
model LottoDraw {
  id             String              @id @default(cuid())
  campaignId     String
  campaign       FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  drawDate       DateTime
  jackpotCents   Int
  winningNumbers Int[]
  bonusNumber    Int?
  winnerSummary  String?
  providerName   String
  providerUrl    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([campaignId, drawDate])
}

// ---------------------------------------------------------------------------
// Kit Design Voting (headless public vote widget)
// ---------------------------------------------------------------------------

/// A kit design entry eligible for public voting.
model KitSubmission {
  id         String       @id @default(cuid())
  title      String
  imageUrl   String?
  votesCount Int          @default(0)
  votes      VoteRecord[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([votesCount])
}

/// Voter fingerprint record — prevents repeat votes from the same client.
model VoteRecord {
  id               String        @id @default(cuid())
  kitSubmissionId  String
  kitSubmission    KitSubmission @relation(fields: [kitSubmissionId], references: [id], onDelete: Cascade)
  voterFingerprint String
  createdAt        DateTime      @default(now())

  @@unique([kitSubmissionId, voterFingerprint])
  @@index([kitSubmissionId])
}

// ---------------------------------------------------------------------------
// Safeguarding & Staff Compliance
// ---------------------------------------------------------------------------

/// Role of a staff member for display, filtering, and compliance routing.
enum StaffRole {
  COACH
  MENTOR
  TEAM_MANAGER
  WELFARE_OFFICER
  COMMITTEE_MEMBER
  VOLUNTEER
}

/// Type of compliance alert raised by the weekly safeguarding cron.
enum ComplianceAlertType {
  VETTING_EXPIRED
  VETTING_EXPIRING_SOON
  SAFEGUARDING_1_MISSING
  SAFEGUARDING_1_OUTDATED
}

/// Lifecycle status of a ComplianceAlert.
enum AlertStatus {
  PENDING
  EMAIL_SENT
  ACKNOWLEDGED
  RESOLVED
}

/// Staff member record tracking FAI compliance status.
/// Public API only returns records where all compliance gates are green.
model StaffMember {
  id                       String            @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String            @unique
  role                     StaffRole         @default(COACH)
  faiCometId               String?
  isGardaVetted            Boolean           @default(false)
  isVettingExpired         Boolean           @default(false)
  gardaVettingApprovedAt   DateTime?
  safeguarding1CompletedAt DateTime?
  isSafeguarding1Current   Boolean           @default(false)
  isClubMarkCompliant      Boolean           @default(false)
  isActivelyCoaching       Boolean           @default(true)
  lastComplianceCheckedAt  DateTime?
  teamAssignments          TeamAssignment[]
  complianceAlerts         ComplianceAlert[]
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([isActivelyCoaching, isClubMarkCompliant])
  @@index([email])
  @@index([lastName, firstName])
}

/// Team assignment linking a staff member to a squad for a given season.
model TeamAssignment {
  id            String      @id @default(cuid())
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  teamName      String
  ageGroup      String
  season        String
  isPrimary     Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([staffMemberId])
  @@index([season, teamName])
}

/// Alert raised by the weekly cron when a compliance deadline is missed or approaching.
model ComplianceAlert {
  id          String              @id @default(cuid())
  staffId     String
  staff       StaffMember         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  alertType   ComplianceAlertType
  status      AlertStatus         @default(PENDING)
  notes       String?
  emailSentAt DateTime?
  triggeredAt DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([staffId, alertType, status])
  @@index([status, triggeredAt])
}

// ---------------------------------------------------------------------------
// Membership Orders & Billing
// ---------------------------------------------------------------------------

/// FAI age-based classification used to determine the applicable membership fee.
enum MemberClassification {
  JUVENILE
  MINOR
  NON_PLAYING_ACTIVE
  PARENT
}

/// Payment lifecycle status for a membership order.
enum MembershipOrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

/// Lifecycle status of a Stripe subscription.
enum SubscriptionStatus {
  OPEN
  PAID
  PAST_DUE
  CANCELLED
}

/// Stripe subscription record supporting one payer for multiple members.
model StripeSubscription {
  id                   String             @id @default(cuid())
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  status               SubscriptionStatus @default(OPEN)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  billingEmail         String
  billingName          String?
  membershipOrders     MembershipOrder[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([status, currentPeriodEnd])
  @@index([billingEmail])
}

/// A family membership order created at checkout, containing one or more members.
model MembershipOrder {
  id                      String                @id @default(cuid())
  status                  MembershipOrderStatus @default(PENDING)
  totalAmountCents        Int
  appliedOption           String?
  contactEmail            String?
  stripeCheckoutSessionId String?               @unique
  stripePaymentIntentId   String?
  subscriptionId          String?
  subscription            StripeSubscription?   @relation(fields: [subscriptionId], references: [id])
  members                 MembershipMember[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([status])
  @@index([stripeCheckoutSessionId])
  @@index([subscriptionId])
  @@index([contactEmail])
}

/// Individual member row within a MembershipOrder.
model MembershipMember {
  id               String               @id @default(cuid())
  orderId          String
  order            MembershipOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  classification   MemberClassification
  teamRegistration String?
  amountCents      Int
  createdAt        DateTime             @default(now())

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Season Registry & Historical Standings
// ---------------------------------------------------------------------------

/// Competitive season record used to scope all historical data.
///
/// Invariant: exactly one row should carry isActive = true at any time.
/// Enforce this at the application layer: when activating a new season, first
/// set all existing rows to isActive = false in the same transaction.
///
/// label format follows the DDSL convention "YYYY/YY" (e.g., "2025/26").
model Season {
  id                  String               @id @default(cuid())
  label               String               @unique
  isActive            Boolean              @default(false)
  historicalStandings HistoricalStanding[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([isActive])
}

/// Immutable final league table row for one team in one division at the close
/// of a completed season.
///
/// Safety rule: always query through ACTIVE_SEASON_WHERE (see lib/db/active-season.ts)
/// so archived seasons never surface in live DDSL data streams.
///
/// onDelete: Restrict on the Season relation prevents accidental data loss —
/// a Season row cannot be deleted while historical standings reference it.
model HistoricalStanding {
  id             String   @id @default(cuid())
  seasonId       String
  season         Season   @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  source         String   @default("DDSL")
  divisionName   String
  position       Int
  teamName       String
  played         Int
  won            Int
  drawn          Int
  lost           Int
  goalsFor       Int
  goalsAgainst   Int
  goalDifference Int
  points         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([seasonId, divisionName])
  @@index([seasonId, divisionName, position])
  @@index([seasonId, source])
  @@index([teamName])
}

/// Timestamped record of a user explicitly accepting terms/disclaimer at the point of
/// any public form submission. Linked to the parent record via submissionType + submissionId.
/// Never delete these rows — they are the legal audit trail.
model TermsAcceptance {
  id             String   @id @default(cuid())
  /// Identifies the form. Use snake_case constants defined in lib/terms/submission-types.ts.
  /// e.g. "anniversary_shirt", "kit_design", "fun_run", "membership"
  submissionType String
  /// The cuid() of the related record (ShirtSubmission.id, FunRunRegistration.id, etc.)
  submissionId   String
  submitterName  String
  submitterEmail String
  /// Increment this string constant whenever the terms wording changes.
  termsVersion   String
  /// x-forwarded-for from the Vercel edge request — may be null in local dev.
  ipAddress      String?
  userAgent      String?
  acceptedAt     DateTime @default(now())

  @@index([submissionType, submissionId])
  @@index([submitterEmail])
  @@index([acceptedAt])
}

/// Anniversary shirt design submission. Requires moderation approval before
/// fulfilment is triggered. TermsAcceptance is recorded separately via
/// buildTermsAcceptanceCreate using the same id generated at submission time.
model ShirtSubmission {
  id               String           @id @default(cuid())
  /// Name of the person placing the order.
  submitterName    String
  submitterEmail   String
  /// Optional: name to print on the shirt.
  playerName       String?
  teamName         String?
  /// Free-text description or special instructions from the submitter.
  designNotes      String?
  /// URL of the uploaded design file (Vercel Blob or equivalent).
  designFileUrl    String
  thumbnailUrl     String?
  size             ClothingSize
  quantity         Int              @default(1)
  /// Starts PENDING. Admin must APPROVE before fulfilment is triggered.
  moderationStatus ModerationStatus @default(PENDING)
  /// Internal reviewer note — visible only in the admin queue.
  moderationNotes  String?
  reviewedAt       DateTime?
  /// Email or identifier of the admin who reviewed this submission.
  reviewedBy       String?
  paymentStatus    PaymentStatus    @default(PENDING)
  paymentReference String?          @unique
  totalAmountCents Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([moderationStatus])
  @@index([submitterEmail])
  @@index([moderationStatus, createdAt])
}

/// Public-facing club announcement — recruitment drives, events,
/// news, and volunteer asks. Surfaced on the homepage and /news page.
/// Auto-hides after expiresAt if set.
model Announcement {
  id          String               @id @default(cuid())
  title       String
  category    AnnouncementCategory
  body        String // markdown, 2-3 paragraphs max
  imageUrl    String? // optional — paste any image URL
  ctaLabel    String? // e.g. "Register Now", "Sign Up"
  ctaUrl      String? // destination for the CTA button
  publishedAt DateTime             @default(now())
  expiresAt   DateTime? // auto-hides after this date if set
  isPublished Boolean              @default(false)
  pinned      Boolean              @default(false) // pins to front of grid
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([isPublished, publishedAt])
  @@index([category, isPublished])
  @@index([pinned, publishedAt])
}

/// Admin-controlled availability for optional public site capabilities.
/// Features default to disabled in application code until explicitly enabled.
model SiteFeature {
  key         String   @id
  label       String
  description String
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

/// Public enquiry captured from a lightweight interest or callback form.
model PublicEnquiry {
  id        String   @id @default(cuid())
  type      String
  name      String
  email     String?
  phone     String?
  details   String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

/// Moderated community equipment listing. Contact information remains private
/// and is available only to club administrators.
model BootRoomListing {
  id               String           @id @default(cuid())
  title            String
  category         String
  size             String?
  itemCondition    String
  description      String
  donorName        String
  donorEmail       String?
  donorPhone       String?
  moderationStatus ModerationStatus @default(PENDING)
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([moderationStatus, createdAt])
  @@index([category, moderationStatus])
}
