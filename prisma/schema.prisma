generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum KitSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FunRunCheckoutStatus {
  DRAFT
  CHECKOUT_CREATED
  PAID
  CANCELLED
  REFUNDED
}

enum DonationProvider {
  SPOTFUND
  PITCHIN
  MANUAL
}

model KitCompetition {
  id                  String                @id @default(cuid())
  slug                String                @unique
  title               String
  subtitle            String?
  templatePdfUrl      String
  downloadLeadCount   Int                   @default(0)
  votingOpen          Boolean               @default(true)
  submissionDeadline  DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  submissions         KitDesignSubmission[]
}

model KitDesignSubmission {
  id              String              @id @default(cuid())
  competitionId   String
  designerName    String
  designerAge     Int?
  guardianName    String?
  email           String
  title           String
  story           String?
  fileUrl         String
  fileMimeType    String
  thumbnailUrl    String?
  status          KitSubmissionStatus @default(PENDING)
  voteCount       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  competition     KitCompetition      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  votes           KitDesignVote[]

  @@index([competitionId, status])
}

model KitDesignVote {
  id             String              @id @default(cuid())
  submissionId   String
  voterHash      String
  createdAt      DateTime            @default(now())
  submission     KitDesignSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, voterHash])
  @@index([voterHash])
}

model KitSubmission {
  id            String       @id @default(cuid())
  designerName  String
  teamName      String
  imageUrl      String
  votesCount    Int          @default(0)
  isApproved    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  voteRecords   VoteRecord[]

  @@index([isApproved, createdAt])
  @@index([votesCount])
}

model VoteRecord {
  id                 String        @id @default(cuid())
  kitSubmissionId    String
  voterFingerprint   String
  createdAt          DateTime      @default(now())
  kitSubmission      KitSubmission @relation(fields: [kitSubmissionId], references: [id], onDelete: Cascade)

  @@unique([kitSubmissionId, voterFingerprint])
  @@index([voterFingerprint])
}

model FunRunCampaign {
  id                    String               @id @default(cuid())
  slug                  String               @unique
  title                 String
  dateLabel             String
  locationLabel         String
  registrationFeeCents  Int
  stripePriceId         String?
  targetAmountCents     Int
  provider              DonationProvider     @default(SPOTFUND)
  providerCampaignUrl   String?
  providerCampaignId    String?
  raisedAmountCents     Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  merchItems            FunRunMerchItem[]
  registrations         FunRunRegistration[]
  donations             DonationTransaction[]
}

model FunRunMerchItem {
  id             String                  @id @default(cuid())
  campaignId     String
  name           String
  description    String?
  priceCents     Int
  stockQuantity  Int?
  active         Boolean                 @default(true)
  campaign       FunRunCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  selections     FunRunMerchSelection[]

  @@index([campaignId, active])
}

model FunRunRegistration {
  id                         String                  @id @default(cuid())
  campaignId                 String
  participantFirstName       String
  participantLastName        String
  participantAge             Int
  guardianName               String
  guardianEmail              String
  guardianPhone              String
  emergencyContactName       String
  emergencyContactPhone      String
  medicalNotes               String?
  consentToPhotography       Boolean                 @default(false)
  marketingConsent           Boolean                 @default(false)
  checkoutStatus             FunRunCheckoutStatus    @default(DRAFT)
  stripeCheckoutSessionId    String?                 @unique
  totalAmountCents           Int
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  campaign                   FunRunCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  merchSelections            FunRunMerchSelection[]

  @@index([campaignId, checkoutStatus])
  @@index([guardianEmail])
}

model FunRunMerchSelection {
  id              String             @id @default(cuid())
  registrationId  String
  merchItemId     String
  quantity        Int                @default(1)
  unitPriceCents  Int
  registration    FunRunRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  merchItem       FunRunMerchItem    @relation(fields: [merchItemId], references: [id], onDelete: Restrict)

  @@unique([registrationId, merchItemId])
}

model DonationTransaction {
  id                     String          @id @default(cuid())
  campaignId             String
  provider               DonationProvider
  providerTransactionId   String?
  donorDisplayName       String?
  amountCents            Int
  message                String?
  createdAt              DateTime        @default(now())
  campaign               FunRunCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

model LottoWidget {
  id                 String            @id @default(cuid())
  slug               String            @unique
  jackpotCents       Int
  currency           String            @default("EUR")
  nextDrawLabel      String
  providerName       String
  providerUrl        String
  active             Boolean           @default(true)
  updatedAt          DateTime          @updatedAt
  recentResults      LottoDrawResult[]
}

model LottoDrawResult {
  id              String       @id @default(cuid())
  lottoWidgetId   String
  drawDate        DateTime
  numbers         Int[]
  bonusNumber     Int?
  winnerSummary   String?
  jackpotCents    Int
  widget          LottoWidget  @relation(fields: [lottoWidgetId], references: [id], onDelete: Cascade)

  @@index([lottoWidgetId, drawDate])
}

// ---------------------------------------------------------------------------
// FAI Safeguarding & Club Mark Compliance
// ---------------------------------------------------------------------------

enum StaffRole {
  COACH
  MENTOR
  TEAM_MANAGER
  WELFARE_OFFICER
  COMMITTEE_MEMBER
  VOLUNTEER
}

enum ComplianceAlertType {
  VETTING_EXPIRING_SOON
  VETTING_EXPIRED
  SAFEGUARDING_1_MISSING
  SAFEGUARDING_1_OUTDATED
}

enum AlertStatus {
  PENDING
  EMAIL_SENT
  ACKNOWLEDGED
  RESOLVED
}

model StaffMember {
  id                       String            @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String            @unique
  phone                    String?
  role                     StaffRole

  // FAI COMET system identifier — issued by FAI, not nullable once registered
  faiCometId               String?           @unique

  // Garda Vetting — via FAI COMET only (FAI Governance Handbook §12.3–12.4)
  gardaVettingApprovedAt   DateTime?
  isGardaVetted            Boolean           @default(false)
  isVettingExpired         Boolean           @default(false)

  // FAI Safeguarding 1 (Child Welfare & Safeguarding) certificate
  safeguarding1CompletedAt DateTime?
  isSafeguarding1Current   Boolean           @default(false)

  // Derived Club Mark compliance flag — true only when all gates pass
  isClubMarkCompliant      Boolean           @default(false)
  lastComplianceCheckedAt  DateTime?

  // Controls public API visibility
  isActivelyCoaching       Boolean           @default(true)

  teamAssignments          TeamAssignment[]
  complianceAlerts         ComplianceAlert[]

  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([isGardaVetted, isVettingExpired])
  @@index([role])
  @@index([faiCometId])
  @@index([isClubMarkCompliant, isActivelyCoaching])
}

model TeamAssignment {
  id        String      @id @default(cuid())
  staffId   String
  teamName  String      // e.g. "U10 Boys A"
  ageGroup  String      // e.g. "U10"
  season    String      // e.g. "2025-2026"
  isPrimary Boolean     @default(false)
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, teamName, season])
  @@index([teamName, season])
}

model ComplianceAlert {
  id          String              @id @default(cuid())
  staffId     String
  alertType   ComplianceAlertType
  status      AlertStatus         @default(PENDING)
  triggeredAt DateTime            @default(now())
  emailSentAt DateTime?
  resolvedAt  DateTime?
  notes       String?
  staff       StaffMember         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, alertType, status])
  @@index([status, triggeredAt])
}

// ---------------------------------------------------------------------------
// Membership
// ---------------------------------------------------------------------------

enum MemberClassification {
  JUVENILE
  MINOR
  NON_PLAYING_ACTIVE
  PARENT
}

enum MembershipOrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model MembershipOrder {
  id                      String                @id @default(cuid())
  status                  MembershipOrderStatus @default(PENDING)
  totalAmountCents        Int
  appliedOption           String?
  contactEmail            String?
  stripeCheckoutSessionId String?               @unique
  stripePaymentIntentId   String?
  members                 MembershipMember[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([status])
  @@index([stripeCheckoutSessionId])
}

model MembershipMember {
  id               String               @id @default(cuid())
  orderId          String
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  classification   MemberClassification
  teamRegistration String?
  amountCents      Int
  order            MembershipOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
